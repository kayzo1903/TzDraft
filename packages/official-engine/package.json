{
  "name": "@tzdraft/official-engine",
  "version": "0.1.0",
  "description": "Official TZD Rules Engine - CAKE-based engine with Tanzania Draughts-64 official draw rules",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "tanzanian-drafti",
    "draughts",
    "checkers",
    "game-engine",
    "official-rules"
  ],
  "author": "TzDraft Team",
  "license": "MIT",
  "dependencies": {
    "@tzdraft/cake-engine": "file:../cake-engine"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
