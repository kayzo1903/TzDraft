# ──────────────────────────────────────────────────────────────────────────────
# Local development: copy to .env.local and fill in values.
#   cp .env.example .env.local
#
# Production: these are injected as Docker build-args at CI build time.
#   NEXT_PUBLIC_* vars are baked into the JS bundle at build time.
#   Runtime env overrides have NO effect on a pre-built Next.js image.
# ──────────────────────────────────────────────────────────────────────────────

# ─── API ───────────────────────────────────────────────────────────────────
# Backend API base URL (without trailing slash)
# Local dev:   http://localhost:3002
# Production:  https://api.yourdomain.com
NEXT_PUBLIC_API_URL=

# Better Auth frontend URL (must match APP_URL in backend .env)
# Local dev:   http://localhost:3000
# Production:  https://yourdomain.com
NEXT_PUBLIC_BETTER_AUTH_URL=

# ─── Sanity CMS ────────────────────────────────────────────────────────────
# Required for /learn article pages. Get from sanity.io/manage → your project.
# NEXT_PUBLIC_* vars are baked into the JS bundle at build time (not runtime).
# Docker: pass as --build-arg NEXT_PUBLIC_SANITY_PROJECT_ID=<value>
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# ─── Google OAuth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── Sentry (optional — leave blank to disable error tracking) ─────────────
# NEXT_PUBLIC_SENTRY_DSN is used client-side; keep it the same DSN as backend
# or create a separate Sentry project for the frontend.
NEXT_PUBLIC_SENTRY_DSN=

# Required by @sentry/nextjs to upload source maps during CI build
# Generate at: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=tzdraft-frontend
