# ─── Database ──────────────────────────────────────────────────────────────
# Supabase (production) or local postgres (docker-compose)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=production

# ─── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="https://yourdomain.com"

# ─── Auth ──────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="replace-with-a-strong-random-secret"
APP_URL="https://yourdomain.com"
JWT_SECRET="replace-with-a-strong-random-secret"
JWT_EXPIRATION="7d"

# ─── Frontend URL ──────────────────────────────────────────────────────────
FRONTEND_URL="https://yourdomain.com"

# ─── Google OAuth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Email — Resend ────────────────────────────────────────────────────────
RESEND_API_KEY="re_your_resend_api_key"
RESEND_AUTH_DOMAIN="mail.yourdomain.com"
SUPPORT_EMAIL="support@yourdomain.com"

# ─── SMS — BeemAfrica ──────────────────────────────────────────────────────
BEAM_AFRICA_SENDER_ID="YourSenderID"
BEAM_AFRICA_API_KEY="your-beemsms-api-key"
BEAM_AFRICA_SECRET_KEY="your-beemsms-secret-key"

# ─── Sentry (optional — leave blank to disable error tracking) ─────────────
SENTRY_DSN="https://your-sentry-dsn@o0.ingest.sentry.io/0"

# ─── Debug flags (development only) ───────────────────────────────────────
# SIDRA_DEBUG=1
# AUTH_DEBUG_LOG=true
