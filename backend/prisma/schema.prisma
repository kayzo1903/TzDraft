// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & IDENTITY DOMAIN
// ============================================

enum UserRole {
  USER
  ADMIN
}

enum AccountType {
  REGISTERED
  GUEST
  OAUTH_PENDING
}

model User {
  id           String      @id @default(uuid())
  phoneNumber  String      @unique @map("phone_number")
  email        String?     @unique
  username     String      @unique
  name         String? // Real name from OAuth provider (can be duplicate)
  displayName  String      @unique @map("display_name") // Unique identifier shown in games
  passwordHash String?     @map("password_hash") // Optional for OAuth users
  isVerified   Boolean     @default(false) @map("is_verified")
  country      String?     @default("TZ")
  region       String?
  role         UserRole    @default(USER)
  accountType  AccountType @default(REGISTERED) @map("account_type")
  isBanned     Boolean     @default(false) @map("is_banned")
  createdAt    DateTime    @default(now()) @map("created_at")
  lastLoginAt  DateTime?   @map("last_login_at")

  // OAuth fields
  googleId      String? @unique @map("google_id")
  oauthProvider String? @map("oauth_provider") // 'google', 'facebook', etc.

  gamesAsWhite           Game[]                  @relation("WhitePlayer")
  gamesAsBlack           Game[]                  @relation("BlackPlayer")
  rating                 Rating?
  matchmakingQueue       MatchmakingQueue?
  refreshTokens          RefreshToken[]
  verificationTokens     VerificationToken[]
  passwordResetTokens    PasswordResetToken[]
  otpCodes               OtpCode[]
  tournamentsCreated     Tournament[]            @relation("TournamentCreator")
  tournamentParticipants TournamentParticipant[] @relation("TournamentParticipants")
  aiChallengeSessions    AiChallengeSession[]
  matchmakingSearches    MatchmakingSearch[]
  notifications          Notification[]          @relation("UserNotifications")
  PuzzleAttempt          PuzzleAttempt[]

  @@index([country])
  @@index([country, region])
  @@index([accountType])
  @@map("users")
}

// ============================================
// RATING (ELO/ILO System)
// ============================================

model Rating {
  userId String @id @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating      Int      @default(1200)
  gamesPlayed Int      @default(0) @map("games_played")
  lastUpdated DateTime @updatedAt @map("last_updated")

  // Career stats — tracked separately from ELO
  wins                   Int  @default(0)
  losses                 Int  @default(0)
  draws                  Int  @default(0)
  matchmakingWins        Int  @default(0) @map("matchmaking_wins")
  highestAiLevelBeaten   Int? @map("highest_ai_level_beaten")
  highestAiLevelPlayed   Int  @default(0) @map("highest_ai_level_played")
  highestUnlockedAiLevel Int  @default(5) @map("highest_unlocked_ai_level")

  @@index([rating])
  @@map("ratings")
}

// ============================================
// AUTHENTICATION TOKENS
// ============================================

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model VerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

model OtpCode {
  id          String   @id @default(uuid())
  phoneNumber String   @map("phone_number")
  userId      String?  @map("user_id")
  purpose     String
  code        String
  expiresAt   DateTime @map("expires_at")
  verified    Boolean  @default(false)
  attempts    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phoneNumber])
  @@index([phoneNumber, purpose])
  @@index([userId])
  @@map("otp_codes")
}

// ============================================
// GAME DOMAIN (Aggregate Root)
// ============================================

model Game {
  id            String     @id @default(uuid())
  status        GameStatus @default(WAITING)
  gameType      GameType   @map("game_type")
  ruleVersion   String     @default("TZ-8x8-v1") @map("rule_version")
  initialTimeMs Int        @default(600000) @map("initial_time_ms")

  whitePlayerId String? @map("white_player_id")
  blackPlayerId String? @map("black_player_id")
  whitePlayer   User?   @relation("WhitePlayer", fields: [whitePlayerId], references: [id])
  blackPlayer   User?   @relation("BlackPlayer", fields: [blackPlayerId], references: [id])

  whiteElo     Int?    @map("white_elo")
  blackElo     Int?    @map("black_elo")
  aiLevel      Int?    @map("ai_level")
  inviteCode   String? @unique @map("invite_code")
  creatorColor String? @map("creator_color")

  winner    Winner?    @map("winner")
  endReason EndReason? @map("end_reason")

  /// Serialized board state after the latest move (array of PieceSnapshot).
  /// Avoids replaying the full move history on every load.
  boardSnapshot Json? @map("board_snapshot")

  createdAt DateTime  @default(now()) @map("created_at")
  startedAt DateTime? @map("started_at")
  endedAt   DateTime? @map("ended_at")

  // Tournament link — null for regular games
  tournamentMatchGameId String?              @unique @map("tournament_match_game_id")
  tournamentMatchGame   TournamentMatchGame? @relation(fields: [tournamentMatchGameId], references: [id])

  moves Move[]
  clock Clock?

  /// Set to true by the nightly puzzle miner after this game has been scanned.
  /// Prevents duplicate candidate extraction on subsequent runs.
  minedForPuzzles Boolean @default(false) @map("mined_for_puzzles")

  @@index([minedForPuzzles, status, endedAt])
  @@map("games")
}

model AiChallengeSession {
  id          String             @id @default(uuid())
  userId      String             @map("user_id")
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiLevel     Int                @map("ai_level")
  playerColor String             @map("player_color")
  result      AiChallengeResult?
  undoUsed    Boolean            @default(false) @map("undo_used")
  startedAt   DateTime           @default(now()) @map("started_at")
  completedAt DateTime?          @map("completed_at")

  @@index([userId, aiLevel])
  @@index([userId, completedAt])
  @@map("ai_challenge_sessions")
}

// ============================================
// GAME ENUMS
// ============================================

enum GameStatus {
  WAITING
  ACTIVE
  FINISHED
  ABORTED
}

enum GameType {
  RANKED
  CASUAL
  AI
  TOURNAMENT
}

enum Winner {
  WHITE
  BLACK
  DRAW
}

enum EndReason {
  NO_MOVES
  STALEMATE
  CHECKMATE
  RESIGN
  TIME
  DISCONNECT
  DRAW
  DRAW_REPETITION
  DRAW_30_MOVE
  DRAW_THREE_KINGS
  DRAW_ENDGAME
}

enum AiChallengeResult {
  WIN
  LOSS
  DRAW
}

// ============================================
// MOVES DOMAIN (Immutable, Append-Only)
// ============================================

model Move {
  id     String @id @default(uuid())
  gameId String @map("game_id")
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  moveNumber Int    @map("move_number")
  player     Player

  fromSquare      Int   @map("from_square") // 1-32 (dark squares only)
  toSquare        Int   @map("to_square")
  capturedSquares Int[] @map("captured_squares") // Ordered list for multi-capture

  isPromotion    Boolean @default(false) @map("is_promotion")
  isMultiCapture Boolean @default(false) @map("is_multi_capture")

  notation   String @map("notation") // e.g., "22x17x10"
  engineEval Int?   @map("engine_eval") // Centipawn equivalent

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([gameId, moveNumber])
  @@map("moves")
}

enum Player {
  WHITE
  BLACK
}

// ============================================
// CLOCK DOMAIN (Time Control)
// ============================================

model Clock {
  gameId String @id @map("game_id")
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  whiteTimeMs BigInt   @map("white_time_ms")
  blackTimeMs BigInt   @map("black_time_ms")
  lastMoveAt  DateTime @map("last_move_at")

  @@map("clocks")
}

// ============================================
// MATCHMAKING QUEUE
// ============================================

model MatchmakingQueue {
  id       String   @id @default(uuid())
  userId   String   @unique @map("user_id")
  timeMs   Int      @map("time_ms") // 180000 | 300000 | 600000 | 1800000
  socketId String   @map("socket_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  // Future ILO / Glicko-2 fields — nullable, unused until player base grows
  rating     Int?
  rd         Float?
  volatility Float?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("matchmaking_queue")
}

model MatchmakingSearch {
  id           String    @id
  userId       String    @map("user_id")
  timeMs       Int       @map("time_ms")
  status       String
  startedAt    DateTime  @default(now()) @map("started_at")
  endedAt      DateTime? @map("ended_at")
  matchedAt    DateTime? @map("matched_at")
  gameId       String?   @map("game_id")
  cancelReason String?   @map("cancel_reason")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status])
  @@index([startedAt])
  @@index([gameId])
  @@map("matchmaking_searches")
}

// ============================================
// TOURNAMENT DOMAIN — Phase 1: Single Elimination
// ============================================

model Tournament {
  id            String           @id @default(uuid())
  name          String
  descriptionEn String           @map("description_en")
  descriptionSw String           @map("description_sw")
  rulesEn       String?          @map("rules_en")
  rulesSw       String?          @map("rules_sw")
  format        TournamentFormat
  style         TournamentStyle
  status        TournamentStatus @default(DRAFT)
  scope         TournamentScope  @default(GLOBAL)
  country       String?
  region        String?

  // Eligibility filters (all nullable = unrestricted)
  minElo                Int? @map("min_elo")
  maxElo                Int? @map("max_elo")
  minMatchmakingWins    Int? @map("min_matchmaking_wins")
  minAiLevelBeaten      Int? @map("min_ai_level_beaten")
  requiredAiLevelPlayed Int? @map("required_ai_level_played")

  // maxPlayers hard caps by format (enforced in CreateTournamentUseCase):
  //   SINGLE_ELIMINATION → 32
  maxPlayers Int @map("max_players")
  minPlayers Int @default(4) @map("min_players")

  registrationDeadline DateTime? @map("registration_deadline")
  scheduledStartAt     DateTime  @map("scheduled_start_at")
  createdById          String    @map("created_by_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  createdBy    User                    @relation("TournamentCreator", fields: [createdById], references: [id])
  participants TournamentParticipant[]
  rounds       TournamentRound[]

  @@map("tournaments")
}

model TournamentParticipant {
  id           String            @id @default(uuid())
  tournamentId String            @map("tournament_id")
  userId       String            @map("user_id")
  seed         Int?
  eloAtSignup  Int               @map("elo_at_signup")
  status       ParticipantStatus @default(REGISTERED)

  // Knockout formats
  matchWins   Int @default(0) @map("match_wins")
  matchLosses Int @default(0) @map("match_losses")

  // Points formats (Round Robin, Swiss) — unused in Phase 1 SE
  totalGamePoints Float @default(0) @map("total_game_points")

  // Swiss Buchholz tiebreak — unused in Phase 1 SE
  tiebreakScore Float @default(0) @map("tiebreak_score")

  registeredAt DateTime @default(now()) @map("registered_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation("TournamentParticipants", fields: [userId], references: [id])

  @@unique([tournamentId, userId])
  @@map("tournament_participants")
}

model TournamentRound {
  id           String      @id @default(uuid())
  tournamentId String      @map("tournament_id")
  roundNumber  Int         @map("round_number")
  status       RoundStatus @default(PENDING)
  startedAt    DateTime?   @map("started_at")
  completedAt  DateTime?   @map("completed_at")

  tournament Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches    TournamentMatch[]

  @@unique([tournamentId, roundNumber])
  @@map("tournament_rounds")
}

model TournamentMatch {
  id           String       @id @default(uuid())
  roundId      String       @map("round_id")
  tournamentId String       @map("tournament_id")
  player1Id    String?      @map("player1_id")
  player2Id    String?      @map("player2_id")
  status       MatchStatus  @default(PENDING)
  result       MatchResult?

  // Running score for knockout mode
  player1Wins       Int @default(0) @map("player1_wins")
  player2Wins       Int @default(0) @map("player2_wins")
  player1ConsecLoss Int @default(0) @map("player1_consec_loss")
  player2ConsecLoss Int @default(0) @map("player2_consec_loss")
  gamesPlayed       Int @default(0) @map("games_played")

  // Points mode fields (unused in Phase 1 SE)
  player1GamePoints Float @default(0) @map("player1_game_points")
  player2GamePoints Float @default(0) @map("player2_game_points")

  // Active game pointer — null when match is PENDING or COMPLETED
  currentGameId String? @unique @map("current_game_id")

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  round TournamentRound       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  games TournamentMatchGame[]

  @@index([tournamentId])
  @@index([currentGameId])
  @@map("tournament_matches")
}

model TournamentMatchGame {
  id         String           @id @default(uuid())
  matchId    String           @map("match_id")
  gameNumber Int              @map("game_number")
  isExtra    Boolean          @default(false) @map("is_extra")
  result     MatchGameResult?

  match TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  // FK lives on Game side: Game.tournamentMatchGameId → TournamentMatchGame.id
  game  Game?

  @@unique([matchId, gameNumber])
  @@map("tournament_match_games")
}

// ============================================
// TOURNAMENT ENUMS
// ============================================

enum TournamentFormat {
  SINGLE_ELIMINATION
  ROUND_ROBIN
  SWISS
  DOUBLE_ELIMINATION
}

enum TournamentStyle {
  BLITZ
  RAPID
  CLASSICAL
  UNLIMITED
}

enum TournamentStatus {
  DRAFT
  REGISTRATION
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TournamentScope {
  GLOBAL
  COUNTRY
  REGION
}

enum ParticipantStatus {
  REGISTERED
  ACTIVE
  ELIMINATED
  WITHDRAWN
}

enum RoundStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum MatchStatus {
  PENDING
  ACTIVE
  COMPLETED
  BYE
}

enum MatchResult {
  PLAYER1_WIN
  PLAYER2_WIN
  BYE
}

enum MatchGameResult {
  PLAYER1_WIN
  PLAYER2_WIN
  DRAW
}

// ============================================
// NOTIFICATION DOMAIN
// ============================================

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  metadata  Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  TOURNAMENT_REGISTERED
  TOURNAMENT_STARTED
  TOURNAMENT_CANCELLED
  TOURNAMENT_COMPLETED
  MATCH_ASSIGNED
  MATCH_STARTED
  MATCH_RESULT
  ROUND_ADVANCED
  ELIMINATED
}

// ============================================
// PUZZLE DOMAIN
// ============================================

enum PuzzleStatus {
  PENDING
  APPROVED
  REJECTED
}

model Puzzle {
  id String @id @default(uuid())

  /// Board snapshot: JSON array of PieceSnapshot objects.
  pieces Json

  /// 'WHITE' or 'BLACK' — the side that must find the winning move.
  sideToMove String @map("side_to_move")

  /// Ordered list of solution steps. Each step: { from, to, captures[] }.
  solution Json

  /// Engine eval swing (centipawns) used to rank puzzle difficulty.
  evalGap Float @default(0) @map("eval_gap")

  /// Tactical theme: 'capture', 'multi-capture', 'promotion', 'positional', etc.
  theme String @default("positional")

  /// 1 (easiest) – 5 (hardest) derived from evalGap.
  difficulty Int @default(3)

  status PuzzleStatus @default(PENDING)

  /// Optional human-readable title set by an admin at approval time.
  title String?

  /// Set when an admin approves the puzzle and it goes live.
  publishedAt DateTime? @map("published_at")

  /// Game the position was extracted from.
  sourceGameId  String? @map("source_game_id")
  sourceMoveNum Int?    @map("source_move_num")

  createdAt DateTime @default(now()) @map("created_at")

  attempts PuzzleAttempt[]

  @@index([status, difficulty])
  @@index([status, publishedAt])
  @@index([sourceGameId])
  @@map("puzzles")
}

model PuzzleAttempt {
  id       String @id @default(uuid())
  puzzleId String @map("puzzle_id")
  userId   String @map("user_id")

  /// true = player found the correct solution.
  solved      Boolean  @default(false)
  /// Milliseconds the player took to find the solution (or give up).
  timeTakenMs Int?     @map("time_taken_ms")
  createdAt   DateTime @default(now()) @map("created_at")

  puzzle Puzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, puzzleId])
  @@index([puzzleId])
  @@map("puzzle_attempts")
}
