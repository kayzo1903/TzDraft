// ============================================
// MATCHMAKING QUEUE
// ============================================

model MatchmakingQueue {
    id       String   @id @default(uuid())
    userId   String   @unique @map("user_id")
    timeMs   Int      @map("time_ms") // 180000 | 300000 | 600000 | 1800000
    socketId String   @map("socket_id")
    joinedAt DateTime @default(now()) @map("joined_at")

    // Future ILO / Glicko-2 fields — nullable, unused until player base grows
    rating     Int?
    rd         Float?
    volatility Float?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("matchmaking_queue")
}

model MatchmakingSearch {
    id           String   @id
    userId       String   @map("user_id")
    timeMs       Int      @map("time_ms")
    status       String
    startedAt    DateTime @default(now()) @map("started_at")
    endedAt      DateTime? @map("ended_at")
    matchedAt    DateTime? @map("matched_at")
    gameId       String?  @map("game_id")
    cancelReason String?  @map("cancel_reason")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, status])
    @@index([status])
    @@index([startedAt])
    @@index([gameId])
    @@map("matchmaking_searches")
}
