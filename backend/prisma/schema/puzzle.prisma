// ============================================
// PUZZLE DOMAIN
// ============================================

model Puzzle {
  id                String    @id @default(uuid())
  title             String?
  pieces            Json                    // Board snapshot (array of pieces)
  sideToMove        String    @map("side_to_move") // 'WHITE' | 'BLACK'
  solution          Json                    // Array of moves: [{from, to, captures}, ...]
  evalGap           Int       @default(0) @map("eval_gap") // Centipawn evaluation swing
  difficulty        Int       @default(3)   // 1-5 scale
  theme             String    @default("tactical")  // tactical, sacrifice, endgame, etc.
  status            PuzzleStatus @default(PENDING)
  
  // Source game reference
  sourceGameId      String?   @map("source_game_id")
  sourceGame        Game?     @relation(fields: [sourceGameId], references: [id], onDelete: SetNull)
  sourceMoveNum     Int?      @map("source_move_num")
  
  // Metadata
  createdAt         DateTime  @default(now()) @map("created_at")
  publishedAt       DateTime? @map("published_at")
  
  attempts          PuzzleAttempt[]
  ratedBy           UserRatedPuzzle[]

  @@index([status])
  @@index([difficulty])
  @@index([theme])
  @@index([sourceGameId])
  @@map("puzzles")
}

model PuzzleAttempt {
  id        String   @id @default(uuid())
  puzzleId  String   @map("puzzle_id")
  puzzle    Puzzle   @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  solved    Boolean  @default(false)
  timeTaken Int?     @map("time_taken")
  points    Int      @default(0)
  createdAt DateTime @default(now()) @map("attempted_at")

  @@index([puzzleId])
  @@index([userId])
  @@map("puzzle_attempts")
}

// Tracks exactly which puzzle IDs have been rated for each user.
// A row here means the rating was already applied — no second effect ever.
model UserRatedPuzzle {
  userId    String   @map("user_id")
  puzzleId  String   @map("puzzle_id")
  points    Int
  ratedAt   DateTime @default(now()) @map("rated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  puzzle Puzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  @@id([userId, puzzleId])
  @@map("user_rated_puzzles")
}
