// ============================================
// LEAGUE DOMAIN — Football-style Round Robin
// v1.0: 2 games per match, 12 players, 11 rounds
// ============================================

model League {
    id               String       @id @default(uuid())
    name             String
    status           LeagueStatus @default(REGISTRATION)
    startDate        DateTime?    @map("start_date")
    endDate          DateTime?    @map("end_date")
    maxPlayers       Int          @default(12) @map("max_players")
    currentRound     Int          @default(0) @map("current_round")
    roundDurationDays Int         @default(7) @map("round_duration_days")
    createdById      String       @map("created_by_id")
    createdAt        DateTime     @default(now()) @map("created_at")
    updatedAt        DateTime     @updatedAt @map("updated_at")

    createdBy    User                  @relation("LeagueCreator", fields: [createdById], references: [id])
    participants LeagueParticipant[]
    rounds       LeagueRound[]
    matches      LeagueMatch[]

    @@map("leagues")
}

model LeagueParticipant {
    id             String                @id @default(uuid())
    leagueId       String                @map("league_id")
    userId         String                @map("user_id")
    status         LeagueParticipantStatus @default(ACTIVE)
    matchPoints    Int                   @default(0) @map("match_points")
    matchWins      Int                   @default(0) @map("match_wins")
    matchDraws     Int                   @default(0) @map("match_draws")
    matchLosses    Int                   @default(0) @map("match_losses")
    matchesPlayed  Int                   @default(0) @map("matches_played")
    consecutiveMissed Int               @default(0) @map("consecutive_missed")
    /// Total game wins across all matches (0.5 per draw)
    goalsFor       Decimal               @default(0) @map("goals_for") @db.Decimal(5, 1)
    /// Total game wins conceded
    goalsAgainst   Decimal               @default(0) @map("goals_against") @db.Decimal(5, 1)
    /// goalsFor - goalsAgainst
    goalDifference Decimal               @default(0) @map("goal_difference") @db.Decimal(5, 1)
    registeredAt   DateTime              @default(now()) @map("registered_at")

    league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
    user   User   @relation("LeagueParticipants", fields: [userId], references: [id])

    @@unique([leagueId, userId])
    @@index([leagueId, matchPoints(sort: Desc)])
    @@map("league_participants")
}

model LeagueRound {
    id          String      @id @default(uuid())
    leagueId    String      @map("league_id")
    roundNumber Int         @map("round_number")
    status      LeagueRoundStatus @default(PENDING)
    deadline    DateTime?

    league  League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
    matches LeagueMatch[]

    @@unique([leagueId, roundNumber])
    @@map("league_rounds")
}

model LeagueMatch {
    id          String            @id @default(uuid())
    leagueId    String            @map("league_id")
    roundId     String            @map("round_id")
    player1Id   String            @map("player1_id")
    player2Id   String            @map("player2_id")
    status      LeagueMatchStatus @default(SCHEDULED)
    deadline    DateTime?

    /// Goals scored (game wins + 0.5 per draw) — max 2.0 with 2 games
    player1Goals Decimal  @default(0) @map("player1_goals") @db.Decimal(3, 1)
    player2Goals Decimal  @default(0) @map("player2_goals") @db.Decimal(3, 1)

    result      LeagueMatchResult @default(PENDING)
    forfeitedBy String?           @map("forfeited_by")
    voidReason  String?           @map("void_reason")

    completedAt DateTime? @map("completed_at")

    league League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
    round  LeagueRound  @relation(fields: [roundId], references: [id], onDelete: Cascade)
    games  LeagueGame[]
    disconnectionEvents DisconnectionEvent[]

    @@index([leagueId])
    @@index([roundId])
    @@index([player1Id])
    @@index([player2Id])
    @@map("league_matches")
}

model LeagueGame {
    id            String          @id @default(uuid())
    matchId       String          @map("match_id")
    leagueId      String          @map("league_id")
    gameNumber    Int             @map("game_number")
    /// Game 1: player1 is White. Game 2: player2 is White.
    whitePlayerId String          @map("white_player_id")
    blackPlayerId String          @map("black_player_id")
    status        LeagueGameStatus @default(PENDING)
    result        LeagueGameResult @default(PENDING)
    forfeitedBy   String?         @map("forfeited_by")
    completedAt   DateTime?       @map("completed_at")

    match LeagueMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
    // Game entity links back here via game.leagueGameId
    game  Game?

    @@unique([matchId, gameNumber])
    @@map("league_games")
}

model DisconnectionEvent {
    id              String    @id @default(uuid())
    matchId         String    @map("match_id")
    gameId          String    @map("game_id")
    playerId        String    @map("player_id")
    disconnectedAt  DateTime  @map("disconnected_at")
    reconnectedAt   DateTime? @map("reconnected_at")
    forfeitedAt     DateTime? @map("forfeited_at")
    /// Duration of disconnection in seconds (set on reconnect or forfeit)
    duration        Int?

    match LeagueMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

    @@index([matchId])
    @@index([gameId])
    @@map("disconnection_events")
}

// ============================================
// LEAGUE ENUMS
// ============================================

enum LeagueStatus {
    REGISTRATION
    ACTIVE
    COMPLETED
    CANCELLED
}

enum LeagueParticipantStatus {
    ACTIVE
    INACTIVE
    DISQUALIFIED
    WITHDRAWN
}

enum LeagueRoundStatus {
    PENDING
    ACTIVE
    COMPLETED
}

enum LeagueMatchStatus {
    SCHEDULED
    IN_PROGRESS
    COMPLETED
    FORFEITED
    VOIDED
}

enum LeagueMatchResult {
    PLAYER1_WIN
    PLAYER2_WIN
    DRAW
    PENDING
}

enum LeagueGameStatus {
    PENDING
    IN_PROGRESS
    COMPLETED
    FORFEITED
}

enum LeagueGameResult {
    WHITE_WIN
    BLACK_WIN
    DRAW
    PENDING
}
