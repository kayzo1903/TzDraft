// ============================================
// GAME DOMAIN (Aggregate Root)
// ============================================

model Game {
    id          String     @id @default(uuid())
    status      GameStatus @default(WAITING)
    gameType    GameType   @map("game_type")
    ruleVersion String     @default("TZ-8x8-v1") @map("rule_version")
    initialTimeMs Int      @default(600000) @map("initial_time_ms")

    whitePlayerId String? @map("white_player_id")
    blackPlayerId String? @map("black_player_id")
    whitePlayer   User?   @relation("WhitePlayer", fields: [whitePlayerId], references: [id])
    blackPlayer   User?   @relation("BlackPlayer", fields: [blackPlayerId], references: [id])

    whiteElo   Int?    @map("white_elo")
    blackElo   Int?    @map("black_elo")
    aiLevel    Int?    @map("ai_level")
    inviteCode   String? @unique @map("invite_code")
    creatorColor String? @map("creator_color")

    winner    Winner?    @map("winner")
    endReason EndReason? @map("end_reason")

    /// Serialized board state after the latest move (array of PieceSnapshot).
    /// Avoids replaying the full move history on every load.
    boardSnapshot Json? @map("board_snapshot")

    createdAt DateTime  @default(now()) @map("created_at")
    startedAt DateTime? @map("started_at")
    endedAt   DateTime? @map("ended_at")

    // Tournament link — null for regular games
    tournamentMatchGameId String?             @unique @map("tournament_match_game_id")
    tournamentMatchGame   TournamentMatchGame? @relation(fields: [tournamentMatchGameId], references: [id])


    // Puzzle mining
    minedForPuzzles   Boolean   @default(false) @map("mined_for_puzzles")
    puzzles           Puzzle[]

    moves Move[]
    clock Clock?

    @@map("games")
}

model AiChallengeSession {
    id          String              @id @default(uuid())
    userId      String              @map("user_id")
    user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
    aiLevel     Int                 @map("ai_level")
    playerColor String              @map("player_color")
    result      AiChallengeResult?
    undoUsed    Boolean             @default(false) @map("undo_used")
    startedAt   DateTime            @default(now()) @map("started_at")
    completedAt DateTime?           @map("completed_at")

    @@index([userId, aiLevel])
    @@index([userId, completedAt])
    @@map("ai_challenge_sessions")
}

// ============================================
// GAME ENUMS
// ============================================

enum GameStatus {
    WAITING
    ACTIVE
    FINISHED
    ABORTED
}

enum GameType {
    RANKED
    CASUAL
    AI
    TOURNAMENT
    LEAGUE
}

enum Winner {
    WHITE
    BLACK
    DRAW
}

enum EndReason {
    NO_MOVES
    STALEMATE
    CHECKMATE
    RESIGN
    TIME
    DISCONNECT
    DRAW
    DRAW_REPETITION
    DRAW_30_MOVE
    DRAW_THREE_KINGS
    DRAW_ENDGAME
}

enum AiChallengeResult {
    WIN
    LOSS
    DRAW
}
