# ─── Docker Compose local dev ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit it.

# Postgres password used by the local postgres container
POSTGRES_PASSWORD=change_me_in_dev

# Full Postgres connection string (must match POSTGRES_USER/PASSWORD above)
DATABASE_URL=postgresql://tzdraft:change_me_in_dev@postgres:5432/tzdraft

# ─── Auth (backend) ────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=replace-with-a-strong-random-secret
JWT_SECRET=replace-with-a-strong-random-secret
APP_URL=http://localhost:3000

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Google OAuth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email — Resend ────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_AUTH_DOMAIN=
SUPPORT_EMAIL=

# ─── SMS — BeemAfrica ──────────────────────────────────────────────────────
BEAM_AFRICA_SENDER_ID=
BEAM_AFRICA_API_KEY=
BEAM_AFRICA_SECRET_KEY=

# ─── Sentry ────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
