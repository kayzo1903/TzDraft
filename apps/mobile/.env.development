# API Configuration
# EXPO_PUBLIC_API_URL — leave unset; api.ts auto-detects from Expo's hostUri

# Debug / Testing Flags
# Set to "true" to simulate Airplane mode / Network failure
EXPO_PUBLIC_SIMULATE_OFFLINE=false

# Set to "true" to force a 401 on /auth/me for session rehydration testing
# Sanity CMS Configuration
EXPO_PUBLIC_SANITY_PROJECT_ID=wvztgicc
EXPO_PUBLIC_SANITY_DATASET=production
